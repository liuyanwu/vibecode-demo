// 配置说明：使用 Qwen 3.5 Plus 模型
//
// 使用方法 1：通过环境变量
// 在命令行中设置：
// set ANTHROPIC_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
// set ANTHROPIC_API_KEY=your-qwen-api-key
// set ANTHROPIC_MODEL=qwen3.5-plus
// bun run main.tsx
//
// 使用方法 2：通过 .env 文件
// 在项目根目录创建 .env 文件，内容如下：

ANTHROPIC_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ANTHROPIC_API_KEY=your-qwen-api-key-here
ANTHROPIC_MODEL=qwen3.5-plus

// 可选配置：
// ANTHROPIC_SMALL_FAST_MODEL=qwen3.5-plus  // 快速模型也使用 Qwen
